# frozen_string_literal: true

# hl up -av
# hl shutdown

dockerfile 'docker/unit/Dockerfile'

expose 3000

app_params <<-PARAMS
  -e RAILS_ENV=development
  -e DATABASE_URL=postgres://postgres:postgres@<%= db_container_name %>
  -e ELASTICSEARCH_URL=http://elasticsearch:9200
  -e CHROME_HOSTNAME=chrome
PARAMS

plugin :database

def_db postgres: {
  root_password: 'postgres',
  version: '17-alpine', # pinning this because 18 breakssss
  port: 5432
}

# Database reset command
db_reset_command 'bin/rails db:reset'

# Elasticsearch for our search
service 'elasticsearch',
  image: 'elasticsearch:9.4.2',
  env: {
    'discovery.type' => 'single-node'
  }

# PGAdmin — web-based PostgreSQL manager (port 5050 on host)
# service 'pgadmin',
#   image: 'dpage/pgadmin4:4',
#   env: {
#     'PGADMIN_DEFAULT_EMAIL'    => 'admin@example.com',
#     'PGADMIN_DEFAULT_PASSWORD' => 'admin'
#   },
#   binds: { './pgadmin_servers.json' => '/pgadmin4/servers.json' }

# # Video recording for browser tests
# service 'video',
#   image: 'davidsiaw/vrec',
#   env: {
#     'HOST'   => 'chrome:5900',
#     'MP4LOC' => '/var/output/out.mp4',
#     'GIVEUID' => '1000',
#     'GIVEGID' => '1000'
#   },
#   binds: { './vidoutput' => '/var/output' }

attach_mount 'app',   '/srv/app'
attach_mount 'lib',   '/srv/lib'
attach_mount 'config', '/srv/config'
attach_mount 'db',    '/srv/db'
attach_mount 'spec', '/srv/spec'


